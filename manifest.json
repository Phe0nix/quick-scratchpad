{
  "manifest_version": 3,
  "name": "Quick Scratchpad",
  "description": "Capture notes instantly and one-click save from any webpage. Simple, fast, minimal, privacy-first and distraction-free.",
  "version": "1.0.0",
  "action": {
    "default_title": "Quick Scratchpad",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Quick Scratchpad"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}